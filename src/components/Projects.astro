        <div class="flex items-center gap-2">
          <button id="project-image-fit-btn" type="button" class="mui-btn-secondary mui-btn-sm project-image-viewer-btn">Fit</button>
          <button id="project-image-zoom-btn" type="button" class="mui-btn-secondary mui-btn-sm project-image-viewer-btn">100%</button>
          <button id="project-image-close-btn" type="button" class="w-10 h-10 rounded-full flex items-center justify-center transition-all duration-200 hover:scale-110 cursor-pointer project-image-viewer-btn" aria-label="Close image viewer">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      {/* Viewer Stage / Scroll container */}
      <div class="relative flex-1 min-h-0 pointer-events-auto">
        <div id="project-image-viewer-scroll" class="w-full h-full overflow-auto rounded-2xl transition-all duration-240 ease-out project-image-viewer-scroll" style="opacity: 0; transform: scale(0.985);">
          <div id="project-image-viewer-stage" class="min-h-full flex items-center justify-center p-4">
            <div id="project-image-viewer-canvas" class="flex items-center justify-center max-w-full max-h-[78vh]">
              <img
                id="project-image-viewer-img"
                src=""
                alt=""
                class="max-w-full max-h-[78vh] object-contain select-none transition-all duration-300"
                draggable="false"
              />
            </div>
          </div>
        </div>

        {/* Carousel Prev Button */}
        <button
          id="project-image-prev-btn"
          type="button"
          class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full hidden items-center justify-center transition-all duration-200 cursor-pointer select-none z-20 shadow-lg project-image-viewer-nav-btn"
          aria-label="Previous image"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        {/* Carousel Next Button */}
        <button
          id="project-image-next-btn"
          type="button"
          class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full hidden items-center justify-center transition-all duration-200 cursor-pointer select-none z-20 shadow-lg project-image-viewer-nav-btn"
          aria-label="Next image"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  import { animate, utils, spring } from "animejs";

  // 3D Tilt effect on project cards
  document.querySelectorAll<HTMLElement>(".tilt-card").forEach((card) => {
    const inner = card.querySelector(".tilt-card-inner") as HTMLElement;
    if (!inner) return;

    card.addEventListener("mousemove", (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -5;
      const rotateY = ((x - centerX) / centerX) * 5;

      animate(inner, {
        rotateX: rotateX,
        rotateY: rotateY,
        duration: 400,
        ease: "outQuad",
      });
    });

    card.addEventListener("mouseleave", () => {
      animate(inner, {
        rotateX: 0,
        rotateY: 0,
        duration: 600,
        ease: "outElastic(1, 0.6)",
      });
    });
  });

  // ── Near-Fullscreen Project Detail Modal ──
  const overlay = document.getElementById("project-modal-overlay");
  const backdrop = document.getElementById("modal-backdrop");
  const closeBtn = document.getElementById("modal-close-btn");
  const modalContent = document.getElementById("project-modal-content");
  const modalScrollArea = document.getElementById("modal-scroll-area");
  const modalTopTitle = document.getElementById("modal-top-title-text");
  const modalPanels = document.querySelectorAll<HTMLElement>("[data-modal-project]");

  // Project titles for the sticky header
  const projectTitles: Record<string, string> = {};
  document.querySelectorAll<HTMLElement>("[data-modal-project]").forEach((panel) => {
    const key = panel.dataset.modalProject || "";
    const h3 = panel.querySelector("h3");
    if (key && h3) {
      projectTitles[key] = h3.textContent || "";
    }
  });

  // Focus management
  let previouslyFocusedElement: HTMLElement | null = null;
  let isModalAnimating = false;

  function trapFocus(e: KeyboardEvent): void {
    if (e.key !== "Tab" || !modalContent) return;

    const focusableEls = modalContent.querySelectorAll<HTMLElement>(
      'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])'
    );
    if (focusableEls.length === 0) return;

    const firstEl = focusableEls[0];
    const lastEl = focusableEls[focusableEls.length - 1];

    if (e.shiftKey) {
      if (document.activeElement === firstEl) {
        e.preventDefault();
        lastEl.focus();
      }
    } else {
      if (document.activeElement === lastEl) {
        e.preventDefault();
        firstEl.focus();
      }
    }
  }

  function openModal(projectKey: string): void {
    if (!overlay || !backdrop || !modalContent) return;

    // Cancel any in-progress animations on modal elements
    utils.remove(backdrop);
    utils.remove(modalContent);
    isModalAnimating = true;

    // Save the element that triggered the modal for focus restoration
    previouslyFocusedElement = document.activeElement as HTMLElement;

    // Hide all panels, show the target
    modalPanels.forEach((panel) => {
      panel.classList.add("hidden");
      if (panel.dataset.modalProject === projectKey) {
        panel.classList.remove("hidden");
      }
    });

    // Update sticky header title
    if (modalTopTitle) {
      const panel = document.querySelector(`[data-modal-project="${projectKey}"]`);
      const h3 = panel?.querySelector("h3");
      modalTopTitle.textContent = h3?.textContent || "";
      modalTopTitle.setAttribute("data-i18n", `projects.${projectKey}_title`);
    }

    // Show overlay first so the scroll area has layout
    overlay.classList.remove("hidden");
    document.body.style.overflow = "hidden";

    // Reset scroll to top after layout is computed
    requestAnimationFrame(() => {
      if (modalScrollArea) {
        modalScrollArea.scrollTop = 0;
      }
    });

    // Check for reduced motion preference
    const motionOk = !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!motionOk) {
      // Instant show for reduced motion
      (backdrop as HTMLElement).style.opacity = "1";
      (modalContent as HTMLElement).style.opacity = "1";
      (modalContent as HTMLElement).style.transform = "translateY(0) scale(1)";
      closeBtn?.focus();
      document.addEventListener("keydown", trapFocus);
      return;
    }

    // ── Orchestrated entrance choreography ──
    // Phase 1: Backdrop fades in with a soft feel
    animate(backdrop, {
      opacity: [0, 1],
      duration: 400,
      ease: "outQuart",
    });

    // Phase 2: Modal content rises from below with spring-like deceleration
    animate(modalContent, {
      opacity: [0, 1],
      translateY: [40, 0],
      scale: [0.96, 1],
      delay: 100,
      ease: spring({ stiffness: 90, damping: 12 }),
      onComplete: () => {
        isModalAnimating = false;
        // Move focus to close button after animation
        closeBtn?.focus();
        // Enable focus trap
        document.addEventListener("keydown", trapFocus);
      },
    });
  }

  function closeModal(): void {
    if (!overlay || !backdrop || !modalContent) return;

    // Cancel any in-progress animations on modal elements
    utils.remove(backdrop);
    utils.remove(modalContent);
    isModalAnimating = true;

    // Remove focus trap
    document.removeEventListener("keydown", trapFocus);

    const motionOk = !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!motionOk) {
      // Instant hide for reduced motion
      overlay.classList.add("hidden");
      (backdrop as HTMLElement).style.opacity = "0";
      (modalContent as HTMLElement).style.opacity = "0";
      (modalContent as HTMLElement).style.transform = "translateY(40px) scale(0.96)";
      document.body.style.overflow = "";
      previouslyFocusedElement?.focus();
      previouslyFocusedElement = null;
      return;
    }

    // Phase 1: Content drops away quickly with fade
    animate(modalContent, {
      opacity: 0,
      translateY: 24,
      scale: 0.97,
      duration: 280,
      ease: "inQuart",
    });

    // Phase 2: Backdrop fades out slightly behind content
    animate(backdrop, {
      opacity: 0,
      duration: 320,
      delay: 60,
      ease: "inQuart",
      onComplete: () => {
        isModalAnimating = false;
        overlay.classList.add("hidden");
        // Reset transforms for next open
        (modalContent as HTMLElement).style.opacity = "0";
        (modalContent as HTMLElement).style.transform = "translateY(40px) scale(0.96)";
        document.body.style.overflow = "";
        // Restore focus to the element that opened the modal
        previouslyFocusedElement?.focus();
        previouslyFocusedElement = null;
      },
    });
  }

  // ── Attach click handlers to ALL tilt-cards (entire card is clickable) ──
  document.querySelectorAll<HTMLElement>(".tilt-card[data-project-key]").forEach((card) => {
    card.addEventListener("click", (e) => {
      // Don't open modal if clicking an external link
      const target = e.target as HTMLElement;
      if (target.closest(".project-external-link")) return;

      e.preventDefault();
      const key = card.dataset.projectKey || "";
      openModal(key);
    });

    // Also open on Enter/Space for keyboard accessibility
    card.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        const key = card.dataset.projectKey || "";
        openModal(key);
      }
    });
  });

  // Stop external link clicks from propagating to card
  document.querySelectorAll<HTMLElement>(".project-external-link").forEach((link) => {
    link.addEventListener("click", (e) => {
      e.stopPropagation();
    });
  });

  // Close on backdrop click
  backdrop?.addEventListener("click", closeModal);

  // Close on button click
  closeBtn?.addEventListener("click", closeModal);

  // Close on Escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && overlay && !overlay.classList.contains("hidden")) {
      // ONLY close the modal if the image viewer is hidden
      const imgViewer = document.getElementById("project-image-viewer");
      if (imgViewer && !imgViewer.classList.contains("hidden")) {
        return;
      }
      closeModal();
    }
  });

  // Prevent clicks inside modal content from closing
  modalContent?.addEventListener("click", (e) => {
    e.stopPropagation();
  });

  // ── Premium Image Viewer Overlay with Fit / 100% zoom & Carousel ──
  const imageViewer = document.getElementById("project-image-viewer");
  const imageViewerImg = document.getElementById("project-image-viewer-img") as HTMLImageElement | null;
  const imageViewerTitle = document.getElementById("project-image-viewer-title");
  const imageViewerScroll = document.getElementById("project-image-viewer-scroll") as HTMLElement | null;
  const imageViewerFitBtn = document.getElementById("project-image-fit-btn");
  const imageViewerZoomBtn = document.getElementById("project-image-zoom-btn");
  const imageViewerCloseBtn = document.getElementById("project-image-close-btn");
  const imageViewerBackdrop = document.getElementById("project-image-viewer-backdrop");
  const imageViewerStage = document.getElementById("project-image-viewer-stage");
  const imageViewerCounter = document.getElementById("project-image-viewer-counter");
  const imageViewerPrevBtn = document.getElementById("project-image-prev-btn");
  const imageViewerNextBtn = document.getElementById("project-image-next-btn");
  const imageViewerCanvas = document.getElementById("project-image-viewer-canvas");

  let imageViewerItems: { src: string; alt: string }[] = [];
  let imageViewerIndex = 0;
  let imageViewerMode = "fit";
  let zoomScale = 1;
  let isPanning = false;
  let startX = 0;
  let startY = 0;
  let scrollLeft = 0;
  let scrollTop = 0;
  let dragDistance = 0;

  function openImageViewer(items: { src: string; alt: string }[], startIndex: number): void {
    if (!imageViewer || !imageViewerImg || !imageViewerTitle || !imageViewerBackdrop || !imageViewerScroll) return;
    imageViewerItems = items || [];
    imageViewerIndex = startIndex >= 0 && startIndex < imageViewerItems.length ? startIndex : 0;
    
    // Reset layout opacity/scale before showing
    imageViewerBackdrop.style.opacity = "0";
    imageViewerScroll.style.opacity = "0";
    imageViewerScroll.style.transform = "scale(0.985)";

    imageViewer.classList.remove("hidden");
    imageViewer.setAttribute("aria-hidden", "false");
    
    // Load first item
    renderImageViewerItem(true); // pass true to skip transition when opening first time

    // Trigger smooth fade-in and scale-in transition
    requestAnimationFrame(() => {
      if (imageViewerBackdrop) imageViewerBackdrop.style.opacity = "1";
      if (imageViewerScroll) {
        imageViewerScroll.style.opacity = "1";
        imageViewerScroll.style.transform = "scale(1)";
      }
    });
  }

  function renderImageViewerItem(skipTransition: boolean = false): void {
    if (!imageViewerImg || !imageViewerTitle || !imageViewerItems.length) return;
    const currentItem = imageViewerItems[imageViewerIndex];

    const updateContent = () => {
      if (!imageViewerImg) return;
      imageViewerImg.src = currentItem.src;
      imageViewerImg.alt = currentItem.alt;
      imageViewerTitle.textContent = currentItem.alt;

      // Update counter
      if (imageViewerCounter) {
        imageViewerCounter.textContent = `${imageViewerIndex + 1} / ${imageViewerItems.length}`;
      }

      // Toggle navigation arrows visibility
      if (imageViewerItems.length > 1) {
        imageViewerPrevBtn?.classList.remove("hidden");
        imageViewerPrevBtn?.classList.add("flex");
        imageViewerNextBtn?.classList.remove("hidden");
        imageViewerNextBtn?.classList.add("flex");
      } else {
        imageViewerPrevBtn?.classList.add("hidden");
        imageViewerPrevBtn?.classList.remove("flex");
        imageViewerNextBtn?.classList.add("hidden");
        imageViewerNextBtn?.classList.remove("flex");
      }

      // Wait until image loads dimensions before layout calculations
      const onImageReady = () => {
        // Always reset to Fit mode on image change
        setImageFit();

        if (!skipTransition) {
          // Fade in new image
          requestAnimationFrame(() => {
            if (imageViewerImg) {
              imageViewerImg.style.opacity = "1";
              imageViewerImg.style.transform = "scale(1)";
            }
          });
        }
      };

      if (imageViewerImg.complete && imageViewerImg.naturalWidth) {
        onImageReady();
      } else {
        imageViewerImg.onload = onImageReady;
      }
    };

    if (skipTransition) {
      updateContent();
      imageViewerImg.style.opacity = "1";
      imageViewerImg.style.transform = "scale(1)";
    } else {
      // Outward transition: opacity and scale
      imageViewerImg.style.transition = "opacity 120ms ease-out, transform 120ms ease-out";
      imageViewerImg.style.opacity = "0";
      imageViewerImg.style.transform = "scale(0.985)";

      setTimeout(updateContent, 120);
    }
  }

  function goToNextImage(): void {
    if (imageViewerItems.length <= 1) return;
    imageViewerIndex = (imageViewerIndex + 1) % imageViewerItems.length;
    renderImageViewerItem();
  }

  function goToPrevImage(): void {
    if (imageViewerItems.length <= 1) return;
    imageViewerIndex = (imageViewerIndex - 1 + imageViewerItems.length) % imageViewerItems.length;
    renderImageViewerItem();
  }

  function closeImageViewer(): void {
    if (!imageViewer || !imageViewerBackdrop || !imageViewerScroll) return;
    
    // Outward transition for the whole viewer
    imageViewerBackdrop.style.opacity = "0";
    imageViewerScroll.style.opacity = "0";
    imageViewerScroll.style.transform = "scale(0.985)";

    isPanning = false;
    dragDistance = 0;

    setTimeout(() => {
      imageViewer.classList.add("hidden");
      imageViewer.setAttribute("aria-hidden", "true");
      if (imageViewerImg) imageViewerImg.src = "";
      imageViewerItems = [];
      imageViewerIndex = 0;
      setImageFit();
    }, 240);
  }

  function resetImageInlineStyles() {
    if (imageViewerStage) {
      imageViewerStage.style.width = "";
      imageViewerStage.style.height = "";
      imageViewerStage.style.padding = "";
      imageViewerStage.style.boxSizing = "";
    }
    if (imageViewerCanvas) {
      imageViewerCanvas.style.width = "";
      imageViewerCanvas.style.height = "";
      imageViewerCanvas.style.margin = "";
    }
    if (imageViewerImg) {
      imageViewerImg.style.width = "";
      imageViewerImg.style.height = "";
    }
  }

  function setImageFit() {
    imageViewerMode = "fit";
    zoomScale = 0;

    resetImageInlineStyles();

    if (imageViewerStage) {
      imageViewerStage.className =
        "min-h-full flex items-center justify-center p-4 cursor-zoom-in";
    }

    if (imageViewerCanvas) {
      imageViewerCanvas.className =
        "flex items-center justify-center max-w-full max-h-[78vh]";
    }

    if (imageViewerImg) {
      imageViewerImg.className =
        "max-w-full max-h-[78vh] object-contain select-none cursor-zoom-in transition-transform duration-300 ease-out";
    }

    if (imageViewerScroll) {
      imageViewerScroll.className = "w-full h-full overflow-auto rounded-2xl pointer-events-auto transition-all duration-240 ease-out";
      imageViewerScroll.style.touchAction = "";
      imageViewerScroll.scrollLeft = 0;
      imageViewerScroll.scrollTop = 0;
    }

    // Update active button styles
    imageViewerFitBtn?.classList.add("bg-white/10");
    imageViewerZoomBtn?.classList.remove("bg-white/10");
  }

  function setImageZoom(scale = 1) {
    if (!imageViewerImg || !imageViewerScroll) return;
    imageViewerMode = "zoom";
    zoomScale = scale;

    resetImageInlineStyles();

    const naturalWidth = imageViewerImg.naturalWidth;
    const naturalHeight = imageViewerImg.naturalHeight;

    if (!naturalWidth || !naturalHeight) return;

    const canvasWidth = Math.round(naturalWidth * scale);
    const canvasHeight = Math.round(naturalHeight * scale);

    const paddingLeft = 24;
    const paddingRight = 24;
    const paddingTop = 24;
    const paddingBottom = 32;

    if (imageViewerStage) {
      imageViewerStage.className =
        "flex items-start justify-start cursor-grab";
      imageViewerStage.style.width = `${canvasWidth + paddingLeft + paddingRight}px`;
      imageViewerStage.style.height = `${canvasHeight + paddingTop + paddingBottom}px`;
      imageViewerStage.style.padding = `${paddingTop}px ${paddingRight}px ${paddingBottom}px ${paddingLeft}px`;
      imageViewerStage.style.boxSizing = "border-box";
    }

    if (imageViewerCanvas) {
      imageViewerCanvas.className =
        "block shrink-0 max-w-none max-h-none";
      imageViewerCanvas.style.width = `${canvasWidth}px`;
      imageViewerCanvas.style.height = `${canvasHeight}px`;
      imageViewerCanvas.style.margin = "0";
    }

    imageViewerImg.className =
      "block w-full h-full object-contain select-none cursor-grab transition-none max-w-none max-h-none";

    imageViewerImg.style.width = "100%";
    imageViewerImg.style.height = "100%";

    imageViewerScroll.className = "w-full h-full overflow-auto rounded-2xl pointer-events-auto transition-all duration-240 ease-out cursor-grab";
    imageViewerScroll.style.touchAction = "none";

    requestAnimationFrame(() => {
      imageViewerScroll.scrollLeft =
        Math.max(0, (imageViewerScroll.scrollWidth - imageViewerScroll.clientWidth) / 2);

      imageViewerScroll.scrollTop =
        Math.max(0, (imageViewerScroll.scrollHeight - imageViewerScroll.clientHeight) / 2);
    });

    // Update active button styles
    imageViewerZoomBtn?.classList.add("bg-white/10");
    imageViewerFitBtn?.classList.remove("bg-white/10");
  }

  function setImageZoom100() {
    setImageZoom(1);
  }

  function toggleImageZoom() {
    if (imageViewerMode === "fit") {
      setImageZoom100();
    } else {
      setImageFit();
    }
  }

  // Single click zoom toggler on image and stage
  imageViewerImg?.addEventListener("click", (e) => {
    e.preventDefault();
    e.stopPropagation();

    if (dragDistance > 6 || isPanning) return;
    toggleImageZoom();
  });

  imageViewerStage?.addEventListener("click", (e) => {
    if (e.target !== imageViewerStage) return;
    e.preventDefault();
    e.stopPropagation();

    if (dragDistance > 6 || isPanning) return;
    toggleImageZoom();
  });

  // Drag / Pan functionality inside zoom mode (Pointer events)
  if (imageViewerScroll) {
    imageViewerScroll.addEventListener("pointerdown", (event) => {
      if (imageViewerMode !== "zoom") return;

      // Only drag with left click / touch / pen
      if (event.button !== 0 && event.pointerType === "mouse") return;

      isPanning = true;
      imageViewerScroll.setPointerCapture(event.pointerId);
      startX = event.clientX;
      startY = event.clientY;
      scrollLeft = imageViewerScroll.scrollLeft;
      scrollTop = imageViewerScroll.scrollTop;
      dragDistance = 0;

      // Update cursor to grabbing
      imageViewerScroll.classList.remove("cursor-grab");
      imageViewerScroll.classList.add("cursor-grabbing");
      if (imageViewerImg) {
        imageViewerImg.classList.remove("cursor-grab");
        imageViewerImg.classList.add("cursor-grabbing");
      }
      if (imageViewerStage) {
        imageViewerStage.classList.remove("cursor-grab");
        imageViewerStage.classList.add("cursor-grabbing");
      }
    });

    imageViewerScroll.addEventListener("pointermove", (event) => {
      if (!isPanning || imageViewerMode !== "zoom") return;

      event.preventDefault();
      const dx = event.clientX - startX;
      const dy = event.clientY - startY;
      dragDistance = Math.max(dragDistance, Math.sqrt(dx * dx + dy * dy));

      imageViewerScroll.scrollLeft = scrollLeft - dx;
      imageViewerScroll.scrollTop = scrollTop - dy;
    });

    const stopPanning = (event: PointerEvent) => {
      if (!isPanning) return;

      isPanning = false;

      // Restore grab cursors
      imageViewerScroll.classList.remove("cursor-grabbing");
      imageViewerScroll.classList.add("cursor-grab");
      if (imageViewerImg) {
        imageViewerImg.classList.remove("cursor-grabbing");
        imageViewerImg.classList.add("cursor-grab");
      }
      if (imageViewerStage) {
        imageViewerStage.classList.remove("cursor-grabbing");
        imageViewerStage.classList.add("cursor-grab");
      }

      try {
        imageViewerScroll.releasePointerCapture(event.pointerId);
      } catch {}
    };

    imageViewerScroll.addEventListener("pointerup", stopPanning);
    imageViewerScroll.addEventListener("pointercancel", stopPanning);
    imageViewerScroll.addEventListener("pointerleave", stopPanning);
  }

  // Hook project cover click & screenshot mini previews clicks
  document.querySelectorAll<HTMLElement>(".project-image-preview, .project-screenshot-preview").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const galleryDataStr = btn.getAttribute("data-project-gallery");
      const startIndexStr = btn.getAttribute("data-start-index") || "0";
      if (galleryDataStr) {
        try {
          const items = JSON.parse(galleryDataStr);
          const startIndex = parseInt(startIndexStr, 10);
          openImageViewer(items, startIndex);
        } catch (err) {
          console.error("Error parsing project gallery data:", err);
        }
      }
    });
  });

  // Viewer controls
  imageViewerFitBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    setImageFit();
  });

  imageViewerZoomBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    setImageZoom100();
  });

  imageViewerCloseBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    closeImageViewer();
  });

  imageViewerBackdrop?.addEventListener("click", (e) => {
    e.stopPropagation();
    closeImageViewer();
  });

  // Prev / Next button clicks
  imageViewerPrevBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    goToPrevImage();
  });

  imageViewerNextBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    goToNextImage();
  });

  // Prevent closing when clicking inner viewer parts (stage/scroll)
  imageViewerScroll?.addEventListener("click", (e) => {
    // If they dragged the image, prevent closing trigger
    if (dragDistance > 6) {
      e.stopPropagation();
      return;
    }

    if (e.target === imageViewerScroll || e.target === document.getElementById("project-image-viewer-stage")) {
      closeImageViewer();
    } else {
      e.stopPropagation();
    }
  });

  // Close viewer on Escape / Keyboard arrow navigation
  document.addEventListener("keydown", (e) => {
    if (!imageViewer || imageViewer.classList.contains("hidden")) return;

    if (e.key === "Escape") {
      e.preventDefault();
      e.stopPropagation();
      closeImageViewer();
    } else if (e.key === "ArrowRight" && !isPanning) {
      e.preventDefault();
      e.stopPropagation();
      goToNextImage();
    } else if (e.key === "ArrowLeft" && !isPanning) {
      e.preventDefault();
      e.stopPropagation();
      goToPrevImage();
    }
  });

  // Debounced window resize & orientation change handler
  let resizeTimeout: ReturnType<typeof setTimeout> | null = null;
  
  function handleResize() {
    if (!imageViewer || imageViewer.classList.contains("hidden")) return;
    
    isPanning = false;
    dragDistance = 0;
    
    // Clean up grab cursor styling if running
    imageViewerScroll?.classList.remove("cursor-grabbing");
    imageViewerScroll?.classList.add("cursor-grab");
    if (imageViewerImg) {
      imageViewerImg.classList.remove("cursor-grabbing");
      imageViewerImg.classList.add("cursor-grab");
    }
    if (imageViewerStage) {
      imageViewerStage.classList.remove("cursor-grabbing");
      imageViewerStage.classList.add("cursor-grab");
    }
    
    setImageFit();
  }

  window.addEventListener("resize", () => {
    if (resizeTimeout) clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(handleResize, 150);
  });

  window.addEventListener("orientationchange", () => {
    if (resizeTimeout) clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(handleResize, 150);
  });

  if (window.visualViewport) {
    window.visualViewport.addEventListener("resize", () => {
      if (resizeTimeout) clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(handleResize, 150);
    });
  }
</script>
