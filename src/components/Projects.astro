function getStatusColor(status: string): string {
  const s = status.toLowerCase();
  if (s.includes("published") || s.includes("publicado") || s.includes("consolidated") || s.includes("consolidada")) {
    return "badge-base badge-success";
  }
  if (s.includes("completed") || s.includes("completado")) {
    return "badge-base badge-info";
  }
  if (s.includes("development") || s.includes("desarrollo")) {
    return "badge-base badge-warning";
  }
  return "badge-base badge-neutral";
}
---

<section id="projects" class="relative py-24 lg:py-32">
